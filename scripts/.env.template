# Rootstock 3000 SBT Auto-Mint 环境变量模板
# 复制此文件为 .env 并填入你的私钥
# 使用方法：source .env 或 export $(cat .env | xargs)

# ⚠️ 警告：此文件包含敏感信息，绝不要提交到Git！

# 主钱包私钥（必填）
# 格式：0x开头，66个字符（包括0x）
# 示例：PRIVATE_KEY="0xabcd1234567890abcd1234567890abcd1234567890abcd1234567890abcd"
PRIVATE_KEY="0x"

# 可选：RBTC价格（USD）
# 如不设置，脚本会使用配置文件中的默认值
# RBTC_PRICE_USD=69000

# 可选：RPC节点URL
# 如不设置，使用默认的 https://public-node.rsk.co
# RPC_URL="https://public-node.rsk.co"
